GATE ZERO    1 Y=CONST0;
GATE ONE     1 Y=CONST1;
GATE BUF    1 Y=A;                  PIN * NONINV  1 2.5 1 0 1 0
GATE NOT    2 Y=!A;                 PIN * INV     1 2.5 1 0 1 0
GATE AND    4 Y=A*B;                PIN * NONINV  1 5.0 1 0 1 0
GATE NAND   4 Y=!(A*B);             PIN * INV     1 5.0 1 0 1 0
GATE OR     4 Y=A+B;                PIN * NONINV  1 5.0 1 0 1 0
GATE NOR    4 Y=!(A+B);             PIN * INV     1 5.0 1 0 1 0
GATE XOR    5 Y=(A*!B)+(!A*B);      PIN * UNKNOWN 1 7.5 1 0 1 0
GATE XNOR   5 Y=(A*B)+(!A*!B);      PIN * UNKNOWN 1 7.5 1 0 1 0
GATE ANDNOT 4 Y=A*!B;               PIN * UNKNOWN 1 5.0 1 0 1 0
GATE ORNOT  4 Y=A+!B;               PIN * UNKNOWN 1 5.0 1 0 1 0
GATE MUX    4 Y=(A*B)+(S*B)+(!S*A); PIN * UNKNOWN 1 7.5 1 0 1 0
